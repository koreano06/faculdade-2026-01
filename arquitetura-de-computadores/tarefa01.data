section .data
    num1    dq 4
    num2    dq 2

    msg_soma    db "Soma:           4 + 2 = ", 0
    msg_sub     db "Subtracao:      4 - 2 = ", 0
    msg_mul     db "Multiplicacao:  4 * 2 = ", 0
    msg_div     db "Divisao:        4 / 2 = ", 0
    newline     db 10

section .bss
    result_buf  resb 20

section .text
    global _start

int_to_str:
    mov rdi, result_buf
    add rdi, 19
    mov byte [rdi], 0
    mov rbx, 10
    xor rcx, rcx

.loop:
    xor rdx, rdx
    div rbx
    add dl, '0'
    dec rdi
    mov [rdi], dl
    inc rcx
    test rax, rax
    jnz .loop

    mov rsi, rdi
    ret

print_str:
    mov rax, 1
    mov rdi, 1
    syscall
    ret

print_num:
    push rax
    call int_to_str
    mov rdx, rcx
    call print_str
    mov rsi, newline
    mov rdx, 1
    call print_str
    pop rax
    ret

_start:
    mov rsi, msg_soma
    mov rdx, 24
    call print_str
    mov rax, [num1]
    add rax, [num2]
    call print_num

    mov rsi, msg_sub
    mov rdx, 24
    call print_str
    mov rax, [num1]
    sub rax, [num2]
    call print_num

    mov rsi, msg_mul
    mov rdx, 24
    call print_str
    mov rax, [num1]
    imul rax, [num2]
    call print_num

    mov rsi, msg_div
    mov rdx, 24
    call print_str
    mov rax, [num1]
    xor rdx, rdx
    idiv qword [num2]
    call print_num

    mov rax, 60
    xor rdi, rdi
    syscall